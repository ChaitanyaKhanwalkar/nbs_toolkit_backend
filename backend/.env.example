# Local development settings for the backend.
# Copy this file to `.env`, then adjust values for your local machine.
#
# Do not put production Azure credentials in this file.
# Do not commit real secrets.

APP_NAME="Narmada NbS Backend"
APP_ENV="local"
LOG_LEVEL="INFO"

# Beginner note:
# Change DATABASE_URL here when you want the backend to use a different database.
# This default points at the current canonical local SQLite database.
DATABASE_URL="sqlite:///../canonical db/narmada_nbs_canonical.db"

# Example local/dev PostgreSQL URL.
# Use only with non-production credentials that are safe for development.
# DATABASE_URL="postgresql+psycopg://user:password@localhost:5432/narmada_nbs_dev"
